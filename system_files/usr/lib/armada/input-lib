#!/bin/bash
# Shared lid-switch helpers for clamshell devices (e.g. AYN Thor).

# True if $1 (a /dev/input/eventN path) exposes SW_LID (capability bit 0).
armada_dev_has_lid() {
    local cap mask
    cap="/sys/class/input/$(basename "$1")/device/capabilities/sw"
    [[ -r "$cap" ]] || return 1
    read -r mask < "$cap" || return 1
    [[ "$mask" =~ ^[0-9a-fA-F]+$ ]] || return 1
    (( 0x$mask & 1 ))
}

# Echo the first input device exposing SW_LID; non-zero if none.
armada_find_lid_dev() {
    local dev
    for dev in /dev/input/event*; do
        [[ -e "$dev" ]] || continue
        armada_dev_has_lid "$dev" && { echo "$dev"; return 0; }
    done
    return 1
}

# True only when the lid is positively closed. evtest --query exits 10 when the
# switch is set; any other result (open, no lid, query unsupported) fails open.
armada_lid_closed() {
    local dev rc
    dev="$(armada_find_lid_dev)" || return 1
    evtest --query "$dev" EV_SW SW_LID >/dev/null 2>&1; rc=$?
    [[ "$rc" -eq 10 ]]
}
