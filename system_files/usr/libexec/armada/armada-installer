#!/usr/bin/bash
set -euo pipefail
source /usr/lib/armada/bootimg-args

ARMADA_REGISTRY="ghcr.io/virtudude/armada"
DEVICE="${ARMADA_INTERNAL_DEVICE:-/dev/sda}"
ESP_GUID="c12a7328-f81f-11d2-ba4b-00a0c93ec93b"
ESP_MIB=512
BOOT_MIB=1024
# Floor, not target: enough for two bootc deployments plus OTA staging headroom.
ROOT_MIN_MIB=$((32 * 1024))
ANDROID_MIN_MIB=$((8 * 1024))
destructive=0
TARGET=""
BTRFS_OPTS="noatime,compress=zstd:1,discard=async,space_cache=v2"
ASSUME_YES=0
UD_GIB=""
OPERATION=install
INHIBIT_PID=""
SELF=/usr/libexec/armada/armada-installer

# Installed before any destructive step (repartition, mkfs, or reset), so a
# failure after internal storage is modified surfaces the recovery instructions
# rather than leaving the user with an unbootable device and no guidance.
cleanup() {
    local rc=$?
    [[ -n "$INHIBIT_PID" ]] && kill "$INHIBIT_PID" 2>/dev/null || true
    [[ -n "$TARGET" ]] && { umount -R "$TARGET" 2>/dev/null || true; rmdir "$TARGET" 2>/dev/null || true; }
    # A half-done operation is recoverable from the SD card (re-run the installer);
    # PC recovery is the last resort for a device that won't boot the SD at all. On
    # a replace, Android was never touched, so it's safe to say so.
    if (( rc != 0 && destructive == 1 )); then
        case $OPERATION in
            reset)
                echo "ERROR: reset did not finish after internal storage was modified. Re-run the installer from the SD card to finish. Only if the device won't boot the SD: recover with a PC (fastboot erase ROCKNIX)." >&2
                ;;
            replace)
                echo "ERROR: install did not finish after internal storage was modified, but Android is unchanged. Do NOT boot internal storage; re-run the installer from the SD card to finish. Only if the device won't boot the SD: recover with a PC (fastboot erase ROCKNIX)." >&2
                ;;
            *)
                echo "ERROR: install did not finish after internal storage was modified. Do NOT boot internal storage. Re-run the installer from the SD card; only if the device won't boot the SD, recover with a PC (fastboot erase ROCKNIX, then reflash the SD card)." >&2
                ;;
        esac
    fi
    exit $rc
}

# Hold a logind lock for the run so an idle timeout or the power button can't suspend
# the device mid-write; a suspend during repartition or deploy could brick internal
# storage. Released by cleanup.
inhibit_sleep() {
    command -v systemd-inhibit >/dev/null 2>&1 || return 0
    systemd-inhibit --what=sleep:idle --who="Armada Installer" \
        --why="writing internal storage" --mode=block sleep infinity &
    INHIBIT_PID=$!
}

need_root() {
    if [[ $EUID -ne 0 ]]; then
        echo "ERROR: must run as root" >&2
        exit 1
    fi
}

need_cmds() {
    local missing=0
    for cmd in blkid btrfs findmnt jq mkfs.btrfs mkfs.ext4 mkfs.vfat ostree parted partprobe sfdisk sgdisk udevadm; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo "ERROR: missing required command: $cmd" >&2
            missing=1
        fi
    done
    (( missing == 0 )) || exit 1
}

check_device() {
    if [[ ! -b $DEVICE ]]; then
        echo "ERROR: internal storage device $DEVICE not found" >&2
        echo "       set ARMADA_INTERNAL_DEVICE if internal storage isn't /dev/sda" >&2
        exit 1
    fi
}

refuse_self() {
    local src
    src=$(root_source)
    if [[ -z $src ]]; then
        echo "ERROR: cannot determine the boot device; refusing to modify $DEVICE" >&2
        exit 1
    fi
    case "$src" in
        "$DEVICE"*)
            echo "ERROR: booted from $DEVICE; refusing to modify the disk you're running from" >&2
            exit 1
            ;;
    esac
}

confirm() {
    (( ASSUME_YES )) && return 0
    local prompt="$1"
    local answer
    read -rp "$prompt [y/N]: " answer
    [[ $answer =~ ^[Yy]$ ]]
}

root_source() {
    local source
    source=$(findmnt -no SOURCE /sysroot 2>/dev/null || findmnt -no SOURCE /)
    # findmnt reports a btrfs root as /dev/sdaN[/subvol]; strip it so readlink
    # resolves the node (else refuse_self fails open on an internal boot).
    source=${source%%\[*}
    readlink -f "$source"
}

resolve_partlabel() {
    local label="$1"
    local matches=()
    # Restrict to $DEVICE: a duplicate label on another disk must not match.
    mapfile -t matches < <(blkid -t "PARTLABEL=${label}" -o device 2>/dev/null \
        | grep -E "^${DEVICE}p?[0-9]+$" || true)
    if [[ ${#matches[@]} -ne 1 || ! -b ${matches[0]} ]]; then
        echo "ERROR: expected exactly one partition with PARTLABEL=${label} on ${DEVICE}" >&2
        exit 1
    fi
    printf '%s\n' "${matches[0]}"
}

part_node() {
    # /dev/sda + 5 → /dev/sda5, but /dev/mmcblk0 / /dev/nvme0n1 need a 'p': …0p5.
    local dev="$1" num="$2"
    [[ $dev =~ [0-9]$ ]] && echo "${dev}p${num}" || echo "${dev}${num}"
}

# One TSV row per partition: NUM <tab> START_BYTE <tab> END_BYTE(inclusive) <tab> NAME.
# END is the inclusive last byte (start+size-1). Parsed by key from sfdisk --json
# rather than splitting columns: a ':' in a partition name or a stray warning line
# would otherwise shift a field or drop a row, and a row missed after userdata is
# silent data loss.
list_partitions() {
    sfdisk --json "$DEVICE" 2>/dev/null | jq -r '
        .partitiontable as $t
        | ($t.sectorsize // 512) as $ss
        | ($t.partitions // [])[]
        | [ (.node | match("[0-9]+$").string),
            (.start * $ss),
            ((.start + .size) * $ss - 1),
            (.name // "") ]
        | @tsv'
}

partition_names() {
    list_partitions | cut -f4
}

detect_mode() {
    local name
    has_rocknix=0
    has_armada_boot=0
    has_armada_root=0
    has_storage=0

    while IFS= read -r name; do
        case "$name" in
            ROCKNIX) has_rocknix=1 ;;
            ARMADA_BOOT) has_armada_boot=1 ;;
            ARMADA_ROOT) has_armada_root=1 ;;
            STORAGE) has_storage=1 ;;
        esac
    done < <(partition_names)

    if (( has_rocknix || has_armada_boot || has_armada_root || has_storage )); then
        mode=occupied
    else
        mode=fresh
    fi
}

find_userdata() {
    mapfile -t ud_line < <(list_partitions | awk -F'\t' '$4=="userdata"')
    if [[ ${#ud_line[@]} -ne 1 ]]; then
        echo "ERROR: could not uniquely find userdata partition on $DEVICE" >&2
        parted -s "$DEVICE" print >&2
        exit 1
    fi

    IFS=$'\t' read -r UD_NUM UD_START UD_END _ <<< "${ud_line[0]}"
    UD_PART=$(part_node "$DEVICE" "$UD_NUM")
    UD_START_MIB=$(( (UD_START + 1048575) / 1048576 ))
    UD_END_MIB=$(( UD_END / 1048576 ))
    UD_ORIG_GIB=$(( (UD_END_MIB - UD_START_MIB) / 1024 ))
}

require_userdata_last() {
    # The fresh layout claims the freed window and partition numbers UD_NUM+1..+3,
    # both of which assume userdata is the LAST partition. Refuse if anything lies
    # after it (e.g. trailing Android partitions on some Odin 3 layouts) rather than
    # mislabel or overwrite it.
    local num start_b end_b name
    while IFS=$'\t' read -r num start_b end_b name; do
        (( num == UD_NUM )) && continue
        if (( end_b > UD_END )); then
            echo "ERROR: partition #${num} lies after userdata on ${DEVICE}; refusing" >&2
            echo "       (a fresh install assumes userdata is the last partition)." >&2
            parted -s "$DEVICE" print >&2
            exit 1
        fi
    done < <(list_partitions)
}

collect_our_tail() {
    local num start_b end_b name
    OUR_NUMS=()
    OUR_LABELS=()
    OUR_MAX_END=$UD_END
    LINUX_BYTES=0
    OUR_FOREIGN_AFTER=0
    while IFS=$'\t' read -r num start_b end_b name; do
        (( num == UD_NUM )) && continue
        case "$name" in
            ROCKNIX|ARMADA_BOOT|ARMADA_ROOT|STORAGE)
                OUR_NUMS+=("$num")
                OUR_LABELS+=("$name")
                LINUX_BYTES=$((LINUX_BYTES + end_b - start_b))
                (( end_b > OUR_MAX_END )) && OUR_MAX_END=$end_b
                ;;
            *)
                (( end_b > UD_END )) && OUR_FOREIGN_AFTER=1
                ;;
        esac
    done < <(list_partitions)
}

compute_ud_bounds() {
    RESERVE_MIB=$((ESP_MIB + BOOT_MIB + ROOT_MIN_MIB + 64))
    MAX_NEW_UD_MIB=$((UD_END_MIB - UD_START_MIB - RESERVE_MIB))
    MIN_NEW_UD_MIB=$ANDROID_MIN_MIB
    (( MAX_NEW_UD_MIB >= MIN_NEW_UD_MIB ))
}

choose_userdata_size() {
    local max_gib min_gib
    if ! compute_ud_bounds; then
        echo "ERROR: not enough free space; armada needs about $((RESERVE_MIB / 1024)) GiB" >&2
        exit 1
    fi
    min_gib=$((MIN_NEW_UD_MIB / 1024))
    max_gib=$((MAX_NEW_UD_MIB / 1024))

    if [[ -n $UD_GIB ]]; then
        [[ $UD_GIB =~ ^[0-9]+$ ]] || { echo "ERROR: --userdata-gib must be an integer" >&2; exit 2; }
        ud_gib=$UD_GIB
        ud_mib=$((ud_gib * 1024))
        if (( ud_mib < MIN_NEW_UD_MIB || ud_mib > MAX_NEW_UD_MIB )); then
            echo "ERROR: --userdata-gib ${ud_gib} out of range (${min_gib} .. ${max_gib} GiB)" >&2
            exit 2
        fi
        return
    fi

    while :; do
        read -rp "New Android userdata size in GiB [min ${min_gib}, max ${max_gib}]: " ud_gib
        ud_gib=${ud_gib:-$min_gib}
        if ! [[ $ud_gib =~ ^[0-9]+$ ]]; then echo "  enter an integer"; continue; fi
        ud_mib=$((ud_gib * 1024))
        if (( ud_mib < MIN_NEW_UD_MIB || ud_mib > MAX_NEW_UD_MIB )); then
            echo "  out of range: ${min_gib} .. ${max_gib} GiB"; continue
        fi
        break
    done
}

# Fills [esp_start_mib .. region_end_mib] with ROCKNIX/ARMADA_BOOT/ARMADA_ROOT and
# resolves them by label. userdata is the last existing partition either way (fresh
# recreates it, replace leaves it), so the three claim slots UD_NUM+1..+3.
create_linux_partitions() {
    local esp_start_mib="$1" region_end_mib="$2"
    local esp_end_mib boot_start_mib boot_end_mib root_start_mib esp_num boot_num root_num part
    esp_end_mib=$((esp_start_mib + ESP_MIB))
    boot_start_mib=$esp_end_mib
    boot_end_mib=$((boot_start_mib + BOOT_MIB))
    root_start_mib=$boot_end_mib
    esp_num=$((UD_NUM + 1))
    boot_num=$((UD_NUM + 2))
    root_num=$((UD_NUM + 3))

    parted -a optimal -s "$DEVICE" mkpart primary fat32 "${esp_start_mib}MiB" "${esp_end_mib}MiB"
    parted -s "$DEVICE" name "$esp_num" ROCKNIX
    parted -s "$DEVICE" set "$esp_num" boot on
    sgdisk --typecode="${esp_num}:${ESP_GUID}" "$DEVICE" >/dev/null

    parted -a optimal -s "$DEVICE" mkpart primary ext4 "${boot_start_mib}MiB" "${boot_end_mib}MiB"
    parted -s "$DEVICE" name "$boot_num" ARMADA_BOOT

    # End the btrfs at region_end_mib, never 100%: that bound stays inside the window
    # actually owned (the freed userdata window on fresh, the freed Linux window on
    # replace) and never spans a trailing partition.
    parted -a optimal -s "$DEVICE" mkpart primary btrfs "${root_start_mib}MiB" "${region_end_mib}MiB"
    parted -s "$DEVICE" name "$root_num" ARMADA_ROOT

    partprobe "$DEVICE" || true
    udevadm settle

    # Resolve by the labels just set, not by assumed device-node numbers.
    ESP_PART=$(resolve_partlabel ROCKNIX)
    BOOT_PART=$(resolve_partlabel ARMADA_BOOT)
    ROOT_PART=$(resolve_partlabel ARMADA_ROOT)
    for part in "$ESP_PART" "$BOOT_PART" "$ROOT_PART"; do
        [[ -b $part ]] || { echo "ERROR: $part did not appear after partitioning" >&2; exit 1; }
    done
}

# Fresh device: shrink Android userdata to the chosen size, then fill the freed
# space with Armada. Android is reset (superblock zeroed).
install_fresh() {
    local new_ud_end_mib=$((UD_START_MIB + ud_mib))

    cat <<EOF

Plan:
  Android userdata: ${UD_START_MIB} .. ${new_ud_end_mib} MiB (${ud_gib} GiB, will be reset)
  Armada:           ${new_ud_end_mib} .. ${UD_END_MIB} MiB

EOF
    confirm "Proceed with destructive partition changes?" || { echo "Aborted."; exit 0; }

    if findmnt -n "$UD_PART" >/dev/null 2>&1; then
        umount "$UD_PART"
    fi

    # Past this point the original Android userdata partition is gone; a failure
    # leaves no bootable internal layout, so arm the recovery message.
    destructive=1
    parted -s "$DEVICE" rm "$UD_NUM"
    parted -a optimal -s "$DEVICE" mkpart primary ext4 "${UD_START_MIB}MiB" "${new_ud_end_mib}MiB"
    parted -s "$DEVICE" name "$UD_NUM" userdata

    create_linux_partitions "$new_ud_end_mib" "$UD_END_MIB"
    [[ -b $UD_PART ]] || { echo "ERROR: $UD_PART did not appear after partitioning" >&2; exit 1; }
    dd if=/dev/zero of="$UD_PART" bs=1M count=8 status=none
}

# Existing install: delete only its Linux partitions and put Armada in that freed
# space. Android userdata is left exactly as-is: no resize, no wipe.
install_replace() {
    local esp_start_mib region_end_mib win_mib installed n p
    OPERATION=replace
    # First MiB boundary after the untouched userdata, out to the end of the freed
    # Linux region (OUR_MAX_END, the original userdata extent).
    esp_start_mib=$(( (UD_END + 1048576) / 1048576 ))
    region_end_mib=$(( OUR_MAX_END / 1048576 ))
    win_mib=$(( region_end_mib - esp_start_mib ))
    if (( win_mib < ESP_MIB + BOOT_MIB + ROOT_MIN_MIB )); then
        echo "ERROR: the freed Linux space (~$((win_mib / 1024)) GiB) is too small for Armada (needs ~$(( (ESP_MIB + BOOT_MIB + ROOT_MIN_MIB) / 1024 )) GiB)." >&2
        echo "       Use 'armada-installer reset' to return the disk to Android, then install fresh." >&2
        exit 1
    fi
    if (( has_armada_boot || has_armada_root )); then installed="Armada"; else installed="ROCKNIX"; fi

    cat <<EOF

Replace ${installed} with Armada, keeping Android?

  Deleting: ${OUR_LABELS[*]}
  Android userdata (~${UD_ORIG_GIB} GiB): left untouched.
  Armada fills the ~$((win_mib / 1024)) GiB freed by ${installed}.

EOF
    confirm "Replace ${installed} with Armada?" || { echo "Aborted."; exit 0; }

    for n in "${OUR_NUMS[@]}"; do
        p=$(part_node "$DEVICE" "$n")
        if findmnt -n "$p" >/dev/null 2>&1; then
            umount "$p" || { echo "ERROR: $p is mounted and could not be unmounted; aborting before any change." >&2; exit 1; }
        fi
    done

    # Past this point the old Linux install is being torn down; a failure leaves no
    # bootable internal layout, so arm the recovery message. Android is untouched.
    destructive=1
    for n in $(printf '%s\n' "${OUR_NUMS[@]}" | sort -rn); do
        parted -s "$DEVICE" rm "$n"
    done
    create_linux_partitions "$esp_start_mib" "$region_end_mib"
}

base_kargs() {
    local file
    for file in /usr/lib/bootc/kargs.d/*.toml; do
        [[ -f $file ]] || continue
        sed -n '/^kargs = \[/,/^\]/{s/^[[:space:]]*"\([^"]*\)",\?/\1/p}' "$file"
    done
}

set_origin() {
    # A raw `ostree admin deploy` leaves no container origin (bootc upgrade no-ops);
    # copy the booted origin so the internal install tracks the same ghcr ref.
    local src dst ref
    # || true: an empty glob makes ls exit nonzero, which set -e would treat as fatal.
    src=$(ls /ostree/deploy/*/deploy/"${commit}".*.origin 2>/dev/null | head -n1) || true
    dst=$(ls "$TARGET"/ostree/deploy/*/deploy/"${commit}".*.origin 2>/dev/null | head -n1) || true
    if [[ -z $src || -z $dst ]]; then
        echo "WARNING: could not set bootc origin; internal install will NOT receive OTA updates" >&2
        return
    fi
    cp -f "$src" "$dst"
    local ref bare
    ref=$(sed -n 's/^container-image-reference=//p' "$dst" | head -1)
    # Only the signed ghcr image can verify + OTA; anything else (a local build) is
    # left as-is with a warning, not rewritten into a will-reject origin.
    if [[ $ref != *${ARMADA_REGISTRY}[:@]* ]]; then
        echo "WARNING: bootc origin is '${ref:-<none>}', not ${ARMADA_REGISTRY}; OTA updates will NOT work on this install (expected for a locally-built image)." >&2
        return
    fi
    # Anchor to the repo so any transport prefix / @digest form rewrites cleanly to
    # the signed reference, so the internal install verifies the cosign signature.
    bare="${ARMADA_REGISTRY}${ref##*${ARMADA_REGISTRY}}"
    sed -i "s|^container-image-reference=.*|container-image-reference=ostree-image-signed:docker://${bare}|" "$dst"
}

seed_kernel() {
    # armada-bootimg-sync only regenerates /KERNEL at shutdown; seed the first one.
    ESP="$TARGET/boot/efi" BOOTROOT="$TARGET/boot" \
        /usr/libexec/armada/armada-bootimg-update
}

write_fstab() {
    local deploy_dir
    deploy_dir=$(find "$TARGET/ostree/deploy/default/deploy" -mindepth 1 -maxdepth 1 -type d -name "${commit}.*" | sort | tail -n1)
    [[ -n $deploy_dir ]] || { echo "ERROR: could not find ostree deploy dir" >&2; exit 1; }
    mkdir -p "$deploy_dir/etc"
    printf 'UUID=%s /boot auto ro 0 0\n' "$BOOT_UUID" > "$deploy_dir/etc/fstab"
    # Mount the ESP so /KERNEL regen lands on the FAT the ABL reads, not a /boot dir.
    printf 'UUID=%s /boot/efi vfat umask=0077,shortname=winnt 0 2\n' "$ESP_UUID" >> "$deploy_dir/etc/fstab"
    printf 'UUID=%s /var btrfs %s,subvol=var 0 0\n' "$ROOT_UUID" "$BTRFS_OPTS" >> "$deploy_dir/etc/fstab"
    printf 'UUID=%s /var/home btrfs %s,subvol=home 0 0\n' "$ROOT_UUID" "$BTRFS_OPTS" >> "$deploy_dir/etc/fstab"
}

rewrite_bls() {
    local entry version linux initrd ostree_arg options karg bootdir
    # Just-deployed = default = highest BLS version (same helper armada-bootimg-update uses).
    entry=$(armada_default_bls_entry "$TARGET/boot")
    [[ -n $entry ]] || { echo "ERROR: no BLS entry created" >&2; exit 1; }

    version=$(sed -n 's/^version //p' "$entry" | head -1)
    linux=$(sed -n 's/^linux //p' "$entry" | head -1)
    initrd=$(sed -n 's/^initrd //p' "$entry" | head -1)
    ostree_arg=$(grep -o 'ostree=[^ ]*' "$entry" | head -n1 || true)
    [[ -n $linux && -n $initrd && -n $ostree_arg ]] || { echo "ERROR: BLS entry incomplete" >&2; exit 1; }
    [[ $linux == /boot/* ]] || linux="/boot${linux}"
    [[ $initrd == /boot/* ]] || initrd="/boot${initrd}"

    options="root=UUID=${ROOT_UUID} rw boot=UUID=${BOOT_UUID}"
    while IFS= read -r karg; do
        # Armada always uses the btrfs subvol layout, so these rootflags replace kargs.d's.
        [[ $karg == rootflags=* ]] && continue
        options="${options} ${karg}"
    done < <(base_kargs)
    options="${options} rootflags=subvol=root,${BTRFS_OPTS}"
    options="${options} ${ostree_arg}"

    # fdtdir (not a single devicetree): armada-bootimg-update reads this to find
    # the DTBs it appends to /KERNEL, so the ABL model picker can pick among them.
    bootdir=$(dirname "$linux")
    cat > "$entry" <<EOF
title Armada
version ${version:-1}
options ${options}
linux ${linux}
initrd ${initrd}
fdtdir ${bootdir}/dtb
EOF
}

format_root() {
    local tmp
    mkfs.btrfs -f -L root "$ROOT_PART" >/dev/null
    tmp=$(mktemp -d -t armada-root.XXXXXX)
    mount "$ROOT_PART" "$tmp"
    btrfs subvolume create "$tmp/root" >/dev/null
    btrfs subvolume create "$tmp/var" >/dev/null
    btrfs subvolume create "$tmp/home" >/dev/null
    umount "$tmp"
    rmdir "$tmp"
}

mount_root() {
    mount -o "${BTRFS_OPTS},subvol=root" "$ROOT_PART" "$TARGET"
    mkdir -p "$TARGET/var"
    mount -o "${BTRFS_OPTS},subvol=var" "$ROOT_PART" "$TARGET/var"
    mkdir -p "$TARGET/var/home"
    mount -o "${BTRFS_OPTS},subvol=home" "$ROOT_PART" "$TARGET/var/home"
}

deploy_to_internal() {
    local commit

    for part in "$ESP_PART" "$BOOT_PART" "$ROOT_PART"; do
        if findmnt -n "$part" >/dev/null 2>&1; then
            umount "$part"
        fi
    done

    format_root

    TARGET=$(mktemp -d -t armada-install.XXXXXX)

    mount_root
    ostree admin init-fs --modern "$TARGET"

    # ARMADA_ROOT is good; only now reformat the (re)bootable ESP + BOOT. Past this
    # point a failure leaves no bootable boot.img; the trap surfaces the recovery.
    destructive=1
    # The working SD ESP (BIB-made) is FAT16, and the ABL reads FAT16, not FAT32.
    # -S 4096 = device 4 KiB sectors; -s 4 keeps the 512 MiB ESP in FAT16 cluster range.
    mkfs.vfat -F 16 -S 4096 -s 4 -n ROCKNIX "$ESP_PART" >/dev/null
    mkfs.ext4 -F -L boot "$BOOT_PART" >/dev/null
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    BOOT_UUID=$(blkid -s UUID -o value "$BOOT_PART")
    ESP_UUID=$(blkid -s UUID -o value "$ESP_PART")

    mkdir -p "$TARGET/boot"
    mount "$BOOT_PART" "$TARGET/boot"
    mkdir -p "$TARGET/boot/efi"
    mount "$ESP_PART" "$TARGET/boot/efi"

    ostree admin os-init --sysroot="$TARGET" default
    commit=$(ostree admin status --json | jq -r '.deployments[] | select(.booted) | .checksum' | head -n1)
    [[ -n $commit && $commit != null ]] || { echo "ERROR: could not determine booted ostree commit" >&2; exit 1; }

    ostree pull-local --repo="$TARGET/ostree/repo" /sysroot/ostree/repo "$commit"
    # --no-merge: a fresh install takes the image's clean /etc, not the booted
    # system's /etc edits (the default upgrade-style merge would carry them over).
    ostree admin deploy --no-merge --sysroot="$TARGET" --os=default "$commit"

    # Seed /var from the image commit (it carries armada-owned /var/home/armada);
    # ostree admin deploy doesn't populate /var, so the home would land root-owned.
    local varseed
    varseed=$(mktemp -d -t armada-var.XXXXXX)
    ostree checkout --repo="$TARGET/ostree/repo" --subpath=/var "$commit" "$varseed/v"
    cp -a "$varseed/v/." "$TARGET/var/"
    rm -rf "$varseed"

    write_fstab
    set_origin
    rewrite_bls
    seed_kernel
    sync
}

cmd_detect() {
    need_root
    check_device
    detect_mode
    if [[ $mode == occupied ]]; then
        find_userdata
        collect_our_tail
        local installed
        if (( has_armada_boot || has_armada_root )); then
            installed=armada
        elif (( has_rocknix || has_storage )); then
            installed=rocknix
        else
            installed=unknown
        fi
        echo "mode=occupied"
        echo "installed=${installed}"
        echo "android_gib=${UD_ORIG_GIB}"
        echo "linux_gib=$(( LINUX_BYTES / 1073741824 ))"
    else
        find_userdata
        if compute_ud_bounds; then
            echo "mode=fresh"
            echo "android_min_gib=$((MIN_NEW_UD_MIB / 1024))"
            echo "android_max_gib=$((MAX_NEW_UD_MIB / 1024))"
            echo "android_current_gib=${UD_ORIG_GIB}"
        else
            echo "mode=toosmall"
            echo "needed_gib=$((RESERVE_MIB / 1024))"
            echo "android_current_gib=${UD_ORIG_GIB}"
        fi
    fi
}

cmd_install() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--assume-yes) ASSUME_YES=1 ;;
            --userdata-gib) UD_GIB="${2:-}"; shift ;;
            --userdata-gib=*) UD_GIB="${1#*=}" ;;
            *) echo "ERROR: unknown argument: $1" >&2; exit 2 ;;
        esac
        shift
    done

    need_root
    need_cmds
    check_device
    refuse_self
    trap cleanup EXIT
    inhibit_sleep

    detect_mode
    case "$mode" in
        occupied)
            # An existing ROCKNIX/Armada install: replace its Linux partitions in
            # place, keeping Android. (Reclaiming the space for Android is `reset`.)
            find_userdata
            collect_our_tail
            (( ${#OUR_NUMS[@]} >= 1 )) || { echo "ERROR: found no removable ROCKNIX/Armada partitions on $DEVICE" >&2; exit 1; }
            if (( OUR_FOREIGN_AFTER )); then
                echo "ERROR: an unrecognized partition lies after userdata on $DEVICE; refusing." >&2
                parted -s "$DEVICE" print >&2
                exit 1
            fi
            install_replace
            ;;
        fresh)
            find_userdata
            require_userdata_last
            cat <<EOF

No internal Armada install was found.

Current Android userdata: ${UD_ORIG_GIB} GiB (${UD_START_MIB}MiB .. ${UD_END_MIB}MiB)

Fresh install will shrink Android userdata, wipe Android user data, create
ROCKNIX/ARMADA_BOOT/ARMADA_ROOT, and install the running Armada image.

After install, internal storage boots before SD. To remove it later and give
the space back to Android, run: armada-installer reset

EOF
            confirm "Resize Android userdata and install Armada?" || { echo "Aborted."; exit 0; }
            choose_userdata_size
            install_fresh
            ;;
    esac

    deploy_to_internal

    cat <<EOF

Install complete.
Power off, remove the SD card, then power on.

EOF
}

cmd_reset() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--assume-yes) ASSUME_YES=1 ;;
            *) echo "ERROR: unknown argument: $1" >&2; exit 2 ;;
        esac
        shift
    done

    OPERATION=reset
    need_root
    need_cmds
    check_device
    refuse_self
    trap cleanup EXIT
    inhibit_sleep

    detect_mode
    [[ $mode == occupied ]] || { echo "Nothing to remove: no ROCKNIX or Armada install found on $DEVICE." >&2; exit 1; }

    find_userdata
    collect_our_tail
    (( ${#OUR_NUMS[@]} >= 1 )) || { echo "ERROR: found no removable ROCKNIX/Armada partitions on $DEVICE" >&2; exit 1; }
    if (( OUR_FOREIGN_AFTER )); then
        echo "ERROR: an unrecognized partition lies after userdata on $DEVICE; refusing to remove." >&2
        parted -s "$DEVICE" print >&2
        exit 1
    fi

    local new_ud_end_mib new_ud_gib installed n p
    new_ud_end_mib=$(( OUR_MAX_END / 1048576 ))
    new_ud_gib=$(( (new_ud_end_mib - UD_START_MIB) / 1024 ))
    if (( has_armada_boot || has_armada_root )); then installed="Armada"; else installed="ROCKNIX"; fi

    cat <<EOF

Remove ${installed} from internal storage?

  Deleting: ${OUR_LABELS[*]}
  Android userdata grows back to ~${new_ud_gib} GiB (full internal storage).
  Android factory-resets (its userdata re-initializes) on next Android boot.

EOF
    confirm "Remove ${installed} and restore Android to full disk?" || { echo "Aborted."; exit 0; }

    # Unmount every target BEFORE any destructive change. If one won't unmount,
    # abort here (destructive still 0) rather than delete partitions and have
    # parted refuse the resize later, mid-teardown.
    for n in "${OUR_NUMS[@]}"; do
        p=$(part_node "$DEVICE" "$n")
        if findmnt -n "$p" >/dev/null 2>&1; then
            umount "$p" || { echo "ERROR: $p is mounted and could not be unmounted; aborting before any change." >&2; exit 1; }
        fi
    done
    if findmnt -n "$UD_PART" >/dev/null 2>&1; then
        umount "$UD_PART" || { echo "ERROR: $UD_PART is mounted and could not be unmounted; aborting before any change." >&2; exit 1; }
    fi

    # Past this point the layout is being torn down; a failure leaves internal
    # storage half-modified, so arm the recovery message.
    destructive=1
    # Highest number first: deleting a lower number would renumber the rest.
    for n in $(printf '%s\n' "${OUR_NUMS[@]}" | sort -rn); do
        parted -s "$DEVICE" rm "$n"
    done
    # resizepart preserves userdata's GPT type GUID + name (so Android still finds
    # it); only the end LBA moves out to reclaim the freed window.
    parted -a optimal -s "$DEVICE" resizepart "$UD_NUM" "${new_ud_end_mib}MiB"

    partprobe "$DEVICE" || true
    udevadm settle
    [[ -b $UD_PART ]] || { echo "ERROR: $UD_PART missing after resize" >&2; exit 1; }
    dd if=/dev/zero of="$UD_PART" bs=1M count=8 status=none
    sync

    cat <<EOF

${installed} removed. Android userdata restored to full internal storage.
Remove the SD card and reboot to use Android, or relaunch the installer to
install Armada again.

EOF
}

# Escape Pango markup specials so an interpolated value (e.g. the "&" in a label)
# can't break a --text dialog. Button labels aren't markup, so don't escape those.
esc() {
    local s="$1"
    s="${s//&/&amp;}"; s="${s//</&lt;}"; s="${s//>/&gt;}"
    printf '%s' "$s"
}

gui_die() {
    zenity --error --title="$GUI_TITLE" --width=460 --text="$1" >/dev/null 2>&1
    exit 1
}

# Heartbeat drives the dialog (the install's output is too sparse to); wait gives the true code.
gui_run() {
    local text="$1" pid; shift
    sudo "$SELF" "$@" >"$GUI_LOG" 2>&1 &
    pid=$!
    ( while kill -0 "$pid" 2>/dev/null; do printf '\n'; sleep 1; done ) \
        | zenity --progress --pulsate --auto-close --no-cancel \
            --title="$GUI_TITLE" --width=480 --text="$text" >/dev/null 2>&1
    wait "$pid"
}

gui_offer_poweroff() {
    zenity --question --title="$GUI_TITLE" --icon="$GUI_ICON" --width=460 --no-wrap \
        --ok-label="Power off" --cancel-label="Close" --text="$1" \
        && sudo systemctl poweroff || true
}

gui_install_flow() {
    local info="$1" amin amax acur default_android ud
    amin=$(sed -n 's/^android_min_gib=//p' <<<"$info")
    amax=$(sed -n 's/^android_max_gib=//p' <<<"$info")
    acur=$(sed -n 's/^android_current_gib=//p' <<<"$info")

    zenity --question --title="$GUI_TITLE" --icon="$GUI_ICON" --width=480 --no-wrap \
        --ok-label="Continue" --cancel-label="Cancel" \
        --text="<b>Install Armada alongside Android?</b>\n\nThis <b>factory-resets Android</b>: you lose installed Android apps and data\n(the Android system itself is kept). Your SD card is not touched.\n\nRecovery from a failed install needs a PC." \
        || exit 0

    # Default Android to a usable size when there's room, else the floor
    # (Armada-first).
    default_android=$amin
    (( amax >= 32 )) && default_android=32
    ud=$(zenity --scale --title="$GUI_TITLE" --icon="$GUI_ICON" \
        --text="<b>Choose Android's size</b>\n\nThe slider sets Android's storage in GB.\nArmada gets the rest.\n\nCurrent Android: <b>${acur} GB</b>." \
        --min-value="$amin" --max-value="$amax" --value="$default_android" --step=4) \
        || exit 0

    zenity --question --title="$GUI_TITLE" --icon="$GUI_ICON" --width=480 --no-wrap \
        --ok-label="Install" --cancel-label="Cancel" \
        --text="<b>Ready to install</b>\n\nAndroid:  <b>${ud} GB</b>\nArmada:  <b>$((acur - ud)) GB</b>\n\nResizing Android <b>factory-resets it</b>: you lose installed apps and data (the Android system is kept).\n\nThis <b>can't be undone</b> without a PC." \
        || exit 0

    gui_run "Installing Armada, do not power off…" install --assume-yes --userdata-gib "$ud" \
        || gui_die "Install failed (details in ${GUI_LOG}).\n\nIf internal storage was modified, recover with a PC:\n  fastboot erase ROCKNIX"
    gui_offer_poweroff "<b>Install complete.</b>\n\nPower off, remove the SD card, then power on."
}

gui_manage_flow() {
    local info="$1" installed android linux name primary remove out rc
    installed=$(sed -n 's/^installed=//p' <<<"$info")
    android=$(sed -n 's/^android_gib=//p' <<<"$info")
    linux=$(sed -n 's/^linux_gib=//p' <<<"$info")
    case "$installed" in
        armada) name="Armada";  primary="Reinstall Armada" ;;
        rocknix) name="ROCKNIX"; primary="Switch to Armada" ;;
        *) gui_die "Internal storage has an unrecognized Linux layout.\n\nThis tool only manages installs it created. Recover from a PC." ;;
    esac
    remove="Remove & Restore Android"
    local name_e remove_e primary_e
    name_e=$(esc "$name"); remove_e=$(esc "$remove"); primary_e=$(esc "$primary")

    # Three choices: primary (keep Android) = OK; remove (wipe Android) = extra
    # button (echoed on stdout, exit 1); Cancel/close = exit 1, no stdout.
    out=$(zenity --question --title="$GUI_TITLE" --icon="$GUI_ICON" --width=540 --no-wrap \
        --ok-label="$primary" --extra-button="$remove" --cancel-label="Cancel" \
        --text="<b>${name_e} is installed on internal storage.</b>\n\nAndroid:  <b>${android} GB</b>\n${name_e}:  <b>${linux} GB</b>\n\n<b>${remove_e}</b> erases everything and gives the disk back to Android.\n<b>${primary_e}</b> keeps your Android.") && rc=0 || rc=$?

    if (( rc == 0 )); then
        gui_run "Installing Armada, do not power off…" install --assume-yes \
            || gui_die "Install failed (details in ${GUI_LOG}).\n\nIf internal storage was modified, recover with a PC:\n  fastboot erase ROCKNIX"
        gui_offer_poweroff "<b>Armada installed.</b> Your Android is unchanged.\n\nPower off, remove the SD card, then power on."
    elif [[ "$out" == "$remove" ]]; then
        zenity --question --title="$GUI_TITLE" --icon="$GUI_ICON" --width=500 --no-wrap \
            --ok-label="Remove" --cancel-label="Cancel" \
            --text="<b>Remove ${name_e} and give all storage back to Android?</b>\n\nThis ERASES ${name_e} and factory-resets Android. <b>It can't be undone.</b>" \
            || exit 0
        gui_run "Removing ${name}, do not power off…" reset --assume-yes \
            || gui_die "Remove failed (details in ${GUI_LOG})."
        gui_offer_poweroff "<b>${name_e} removed.</b> Android has the full internal disk again.\n\nPower off and remove the SD card to boot Android, or relaunch to install Armada."
    fi
}

cmd_gui() {
    GUI_TITLE="Armada Installer"
    GUI_ICON="drive-harddisk"
    GUI_LOG=/tmp/armada-installer.log
    command -v zenity >/dev/null 2>&1 || { echo "zenity not installed" >&2; exit 1; }

    local info gmode
    info=$(sudo "$SELF" detect 2>/dev/null) || gui_die "Couldn't inspect internal storage."
    gmode=$(sed -n 's/^mode=//p' <<<"$info")
    case "$gmode" in
        fresh) gui_install_flow "$info" ;;
        occupied) gui_manage_flow "$info" ;;
        toosmall)
            local need
            need=$(sed -n 's/^needed_gib=//p' <<<"$info")
            gui_die "Internal storage is too small to install Armada.\n\nArmada needs about ${need} GB free on internal storage." ;;
        *) gui_die "Unexpected internal-storage state: ${gmode:-unknown}." ;;
    esac
}

usage() {
    cat >&2 <<EOF
Usage: armada-installer <command>

  gui              desktop (zenity) front-end to install or manage the install
  detect           read-only probe: print mode + sizes (k=v)
  install [opts]   fresh install of the running image to internal storage
                     -y, --assume-yes        skip prompts
                     --userdata-gib N         new Android userdata size
  reset [opts]     remove ROCKNIX/Armada and grow Android back to full disk
                     -y, --assume-yes        skip prompts
EOF
    exit 2
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift
case "$cmd" in
    gui) cmd_gui "$@" ;;
    detect) cmd_detect "$@" ;;
    install) cmd_install "$@" ;;
    reset) cmd_reset "$@" ;;
    -h|--help|help|"") usage ;;
    *) echo "ERROR: unknown command: $cmd" >&2; usage ;;
esac
