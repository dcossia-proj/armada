#!/bin/bash
# Dispatch to fake-suspend or real suspend per ARMADA_SUSPEND_MODE.
set -uo pipefail

eval "$(/usr/libexec/armada/device-env 2>/dev/null)" || true
mode="${ARMADA_SUSPEND_MODE:-fake}"

if [[ "$mode" == "fake" ]]; then
    exec /usr/libexec/armada/fake-suspend sleep
fi

# Real suspend: prefer systemd-sleep so its sleep hooks and process freeze run.
for sleep_bin in /usr/lib/systemd/systemd-sleep /lib/systemd/systemd-sleep; do
    [[ -x "$sleep_bin" ]] && exec "$sleep_bin" suspend "$@"
done
# No systemd-sleep found: write the state directly rather than leave sleep dead.
echo "$mode" > /sys/power/state
