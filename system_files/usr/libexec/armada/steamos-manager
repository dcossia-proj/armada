#!/usr/bin/env python3
import os
import signal
import shlex
import subprocess
import sys
import warnings

import gi

gi.require_version("Gio", "2.0")
from gi.repository import GLib, Gio


warnings.filterwarnings("ignore", category=DeprecationWarning)

BUS_NAME = "com.steampowered.SteamOSManager1"
OBJECT_PATH = "/com/steampowered/SteamOSManager1"
IFACE_MANAGER = "com.steampowered.SteamOSManager1.Manager2"
IFACE_PROFILE = "com.steampowered.SteamOSManager1.PerformanceProfile1"
IFACE_GPU = "com.steampowered.SteamOSManager1.GpuPerformanceLevel1"
IFACE_SESSION = "com.steampowered.SteamOSManager1.SessionManagement1"
IFACE_OBJECT_MANAGER = "org.freedesktop.DBus.ObjectManager"

POWER_BUS = "org.armada.Power"
POWER_PATH = "/org/armada/Power"
POWER_IFACE = "org.armada.Power1"
PROPS = "org.freedesktop.DBus.Properties"
POWER_GET_TIMEOUT_MS = 1000
POWER_SET_TIMEOUT_MS = 5000

ROOT_XML = f"""
<node>
  <interface name="{IFACE_OBJECT_MANAGER}">
    <method name="GetManagedObjects">
      <arg type="a{{oa{{sa{{sv}}}}}}" name="objects" direction="out"/>
    </method>
    <signal name="InterfacesAdded">
      <arg type="o" name="object"/>
      <arg type="a{{sa{{sv}}}}" name="interfaces"/>
    </signal>
    <signal name="InterfacesRemoved">
      <arg type="o" name="object"/>
      <arg type="as" name="interfaces"/>
    </signal>
  </interface>
</node>
"""

NODE_XML = f"""
<node>
  <interface name="{IFACE_MANAGER}">
    <method name="ReloadConfig"/>
    <property name="DeviceModel" type="(ss)" access="read"/>
  </interface>
  <interface name="{IFACE_SESSION}">
    <method name="SwitchToDesktopMode"/>
    <method name="SwitchToGameMode"/>
    <method name="SwitchToLoginMode">
      <arg type="s" name="type" direction="in"/>
    </method>
    <method name="SwitchToDesktopSession">
      <arg type="s" name="session" direction="in"/>
    </method>
    <method name="ValidDesktopSessions">
      <arg type="as" name="sessions" direction="out"/>
    </method>
    <method name="CleanTemporarySessions"/>
    <property name="DefaultDesktopSession" type="s" access="readwrite"/>
    <property name="DefaultLoginMode" type="s" access="readwrite"/>
  </interface>
  <interface name="{IFACE_PROFILE}">
    <property name="AvailablePerformanceProfiles" type="as" access="read"/>
    <property name="PerformanceProfile" type="s" access="readwrite"/>
    <property name="SuggestedDefaultPerformanceProfile" type="s" access="read"/>
  </interface>
  <interface name="{IFACE_GPU}">
    <property name="AvailableGpuPerformanceLevels" type="as" access="read"/>
    <property name="GpuPerformanceLevel" type="s" access="readwrite"/>
    <property name="ManualGpuClock" type="u" access="readwrite"/>
    <property name="ManualGpuClockMin" type="u" access="read"/>
    <property name="ManualGpuClockMax" type="u" access="read"/>
  </interface>
</node>
"""


def shell_env():
    helper = os.environ.get("ARMADA_DEVICE_ENV", "/usr/libexec/armada/device-env")
    command = (
        f'eval "$({shlex.quote(helper)})"; '
        'for name in "${!ARMADA_@}"; do printf "%s=%s\\n" "$name" "${!name}"; done'
    )
    proc = subprocess.run(
        ["bash", "-c", command],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    env = {}
    for line in proc.stdout.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            env[key] = value
    return env


class PowerClient:
    def __init__(self):
        self.props = Gio.DBusProxy.new_for_bus_sync(
            Gio.BusType.SYSTEM,
            Gio.DBusProxyFlags.NONE,
            None,
            POWER_BUS,
            POWER_PATH,
            PROPS,
            None,
        )

    def get(self, name):
        result = self.props.call_sync(
            "Get",
            GLib.Variant("(ss)", (POWER_IFACE, name)),
            Gio.DBusCallFlags.NONE,
            POWER_GET_TIMEOUT_MS,
            None,
        )
        return result.get_child_value(0).get_variant()

    def set(self, name, value):
        self.props.call_sync(
            "Set",
            GLib.Variant("(ssv)", (POWER_IFACE, name, value)),
            Gio.DBusCallFlags.NONE,
            POWER_SET_TIMEOUT_MS,
            None,
        )


class ArmadaSteamOSManager:
    def __init__(self):
        self.env = shell_env()
        self.device_id = self.env.get("ARMADA_DEVICE_ID", "armada")
        self.device_name = self.env.get("ARMADA_DEVICE_NAME", "Armada")
        self.default_login_mode = self.env.get("ARMADA_STEAM_DEFAULT_LOGIN_MODE", "game")
        self.default_desktop_session = self.env.get("ARMADA_STEAM_DESKTOP_SESSION", "armada-plasma.desktop")
        self.valid_desktop_sessions = ("armada-plasma.desktop",)
        self.power = PowerClient()
        self.connection = None

    def managed_objects(self):
        objects = {}
        for iface in self.node.interfaces:
            props = {}
            for prop in iface.properties:
                try:
                    value = self.get_property(iface.name, prop.name)
                except Exception as exc:
                    print(
                        f"armada-steamos-manager: skipping {iface.name}.{prop.name}: {exc}",
                        file=sys.stderr,
                    )
                    continue
                if value is not None:
                    props[prop.name] = value
            objects.setdefault(OBJECT_PATH, {})[iface.name] = props
        return objects

    def emit_properties(self, iface, changed):
        self.connection.emit_signal(
            None,
            OBJECT_PATH,
            "org.freedesktop.DBus.Properties",
            "PropertiesChanged",
            GLib.Variant("(sa{sv}as)", (iface, changed, [])),
        )

    def get_property(self, iface, prop):
        if iface == IFACE_MANAGER and prop == "DeviceModel":
            return GLib.Variant("(ss)", (self.device_id, self.device_name))
        if iface == IFACE_SESSION:
            if prop == "DefaultDesktopSession":
                return GLib.Variant("s", self.default_desktop_session)
            if prop == "DefaultLoginMode":
                return GLib.Variant("s", self.default_login_mode)
        if iface == IFACE_PROFILE:
            mapping = {
                "AvailablePerformanceProfiles": "AvailableProfiles",
                "PerformanceProfile": "Profile",
                "SuggestedDefaultPerformanceProfile": "SuggestedDefaultProfile",
            }
            return self.power.get(mapping[prop])
        if iface == IFACE_GPU:
            mapping = {
                "AvailableGpuPerformanceLevels": "AvailableGpuPerformanceLevels",
                "GpuPerformanceLevel": "GpuPerformanceLevel",
                "ManualGpuClock": "ManualGpuClock",
                "ManualGpuClockMin": "ManualGpuClockMin",
                "ManualGpuClockMax": "ManualGpuClockMax",
            }
            return self.power.get(mapping[prop])
        return None

    def set_property(self, iface, prop, value):
        if iface == IFACE_PROFILE and prop == "PerformanceProfile":
            self.power.set("Profile", value)
            try:
                applied = self.power.get("Profile")
            except Exception as exc:
                print(f"armada-steamos-manager: readback Profile failed: {exc}", file=sys.stderr)
                return
            self.emit_properties(iface, {prop: applied})
            return
        if iface == IFACE_GPU and prop == "GpuPerformanceLevel":
            self.power.set("GpuPerformanceLevel", value)
            try:
                applied = self.power.get("GpuPerformanceLevel")
            except Exception as exc:
                print(f"armada-steamos-manager: readback GpuPerformanceLevel failed: {exc}", file=sys.stderr)
                return
            self.emit_properties(iface, {prop: applied})
            return
        if iface == IFACE_GPU and prop == "ManualGpuClock":
            self.power.set("ManualGpuClock", value)
            try:
                applied = self.power.get("ManualGpuClock")
            except Exception as exc:
                print(f"armada-steamos-manager: readback ManualGpuClock failed: {exc}", file=sys.stderr)
                return
            self.emit_properties(iface, {prop: applied})
            return
        if iface == IFACE_SESSION and prop == "DefaultDesktopSession":
            session = value.get_string()
            if session not in self.valid_desktop_sessions:
                raise ValueError(session)
            self.default_desktop_session = session
            self.emit_properties(iface, {prop: value})
            return
        if iface == IFACE_SESSION and prop == "DefaultLoginMode":
            mode = value.get_string()
            if mode not in ("game", "desktop"):
                raise ValueError(mode)
            self.default_login_mode = mode
            self.emit_properties(iface, {prop: value})
            return
        raise KeyError(prop)

    @staticmethod
    def _process_running(name):
        return (
            subprocess.run(
                ["pgrep", "-x", name], stdout=subprocess.DEVNULL
            ).returncode
            == 0
        )

    def switch_session(self, target):
        # On dual-screen devices the desktop compositor stays up and hosts
        # gaming mode as a nested gamescope on the primary screen; switching
        # starts or stops that gamescope instead of swapping SDDM sessions.
        # Only the session-bus instance can manage the user's session.
        if (
            self.env.get("ARMADA_GAMING_SESSION") == "nested"
            and os.geteuid() != 0
            and self._process_running("kwin_wayland")
        ):
            if target == "desktop":
                if self._process_running("gamescope-wl"):
                    subprocess.run(["pkill", "-x", "gamescope-wl"], timeout=10)
                return
            if target == "gamemode":
                subprocess.run(
                    ["systemd-run", "--user", "--collect",
                     "/usr/libexec/armada/nested-gaming"],
                    check=True,
                    timeout=10,
                )
                return

        commands = {
            "desktop": "switch-desktop",
            "gamemode": "switch-gamemode",
        }
        command = ["/usr/libexec/armada/session-control", commands[target]]
        if os.geteuid() != 0:
            command = ["sudo", "-n", *command]
        subprocess.run(command, check=True, timeout=10)

    def switch_login_mode(self, mode):
        if mode == "desktop":
            self.switch_session("desktop")
            return
        if mode in ("", "game", "gamemode", "steam"):
            self.switch_session("gamemode")
            return
        raise ValueError(mode)

    def handle_root_method_call(self, _conn, _sender, _path, iface, method, _params, invocation):
        if iface == IFACE_OBJECT_MANAGER and method == "GetManagedObjects":
            invocation.return_value(GLib.Variant("(a{oa{sa{sv}}})", (self.managed_objects(),)))
            return
        invocation.return_dbus_error(f"{BUS_NAME}.Error.UnknownMethod", method)

    def handle_method_call(self, _conn, _sender, _path, iface, method, _params, invocation):
        if iface == IFACE_MANAGER and method == "ReloadConfig":
            self.power = PowerClient()
            invocation.return_value(None)
            return
        if iface == IFACE_SESSION:
            if method == "ValidDesktopSessions":
                invocation.return_value(GLib.Variant("(as)", (list(self.valid_desktop_sessions),)))
                return
            if method == "SwitchToDesktopMode":
                try:
                    self.switch_session("desktop")
                except Exception as exc:
                    invocation.return_dbus_error(f"{BUS_NAME}.Error.SwitchFailed", str(exc))
                    return
                invocation.return_value(None)
                return
            if method == "SwitchToDesktopSession":
                try:
                    values = _params.unpack()
                    if values and values[0] not in self.valid_desktop_sessions:
                        raise ValueError(values[0])
                    self.switch_session("desktop")
                except Exception as exc:
                    invocation.return_dbus_error(f"{BUS_NAME}.Error.SwitchFailed", str(exc))
                    return
                invocation.return_value(None)
                return
            if method == "SwitchToGameMode":
                try:
                    self.switch_session("gamemode")
                except Exception as exc:
                    invocation.return_dbus_error(f"{BUS_NAME}.Error.SwitchFailed", str(exc))
                    return
                invocation.return_value(None)
                return
            if method == "SwitchToLoginMode":
                try:
                    values = _params.unpack()
                    mode = values[0] if values else self.default_login_mode
                    self.switch_login_mode(mode)
                except Exception as exc:
                    invocation.return_dbus_error(f"{BUS_NAME}.Error.SwitchFailed", str(exc))
                    return
                invocation.return_value(None)
                return
            # Steam probes this on SteamOS; Armada does not create temporary sessions.
            if method == "CleanTemporarySessions":
                invocation.return_value(None)
                return
        invocation.return_dbus_error(f"{BUS_NAME}.Error.UnknownMethod", method)

    def handle_get_property(self, _conn, _sender, _path, iface, prop):
        try:
            return self.get_property(iface, prop)
        except Exception:
            return None

    def handle_set_property(self, _conn, _sender, _path, iface, prop, value):
        try:
            self.set_property(iface, prop, value)
            return True
        except Exception as exc:
            print(f"armada-steamos-manager: set {iface}.{prop} failed: {exc}", file=sys.stderr)
            return False

    def register(self, connection):
        self.connection = connection
        self.root_node = Gio.DBusNodeInfo.new_for_xml(ROOT_XML)
        self.node = Gio.DBusNodeInfo.new_for_xml(NODE_XML)
        connection.register_object(
            "/",
            self.root_node.interfaces[0],
            self.handle_root_method_call,
            None,
            None,
        )
        for iface in self.node.interfaces:
            connection.register_object(
                OBJECT_PATH,
                iface,
                self.handle_method_call,
                self.handle_get_property,
                self.handle_set_property,
            )


def main():
    system_bus = "--system" in sys.argv
    loop = GLib.MainLoop()
    manager = ArmadaSteamOSManager()

    def bus_acquired(connection, _name):
        manager.register(connection)

    def name_lost(_connection, _name):
        loop.quit()

    owner_id = Gio.bus_own_name(
        Gio.BusType.SYSTEM if system_bus else Gio.BusType.SESSION,
        BUS_NAME,
        Gio.BusNameOwnerFlags.NONE,
        bus_acquired,
        None,
        name_lost,
    )
    for sig in (signal.SIGINT, signal.SIGTERM):
        signal.signal(sig, lambda _signum, _frame: loop.quit())
    try:
        loop.run()
    finally:
        Gio.bus_unown_name(owner_id)


if __name__ == "__main__":
    main()
