#!/bin/bash
set -uo pipefail

game_running() {
    local pid
    for pid in $(pgrep -x reaper 2>/dev/null); do
        grep -qa SteamLaunch "/proc/$pid/cmdline" 2>/dev/null && return 0
    done
    return 1
}

prev=""
while :; do
    if game_running; then
        state=game
    else
        state=balanced
    fi
    if [[ "$state" != "$prev" ]]; then
        /usr/libexec/armada/power-control "$state"
        logger -t armada-game-watch "power state -> $state"
        prev="$state"
    fi
    sleep 5
done
